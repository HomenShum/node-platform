{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.evolution-evidence.v1.schema.json",
  "type": "object",
  "required": ["schemaVersion", "id", "kind", "artifactRef", "sha256", "sourceCommit", "generatedAt", "verifiesInvariantIds", "result"],
  "properties": {
    "schemaVersion": { "const": "nodekit.evolution-evidence/v1" },
    "id": { "$ref": "#/$defs/id" },
    "kind": { "enum": ["test", "benchmark", "code", "trace", "screenshot", "interaction-clip", "artifact", "deployment", "human-review"] },
    "artifactRef": { "$ref": "#/$defs/text" },
    "sha256": { "$ref": "#/$defs/hash" },
    "sourceCommit": { "$ref": "#/$defs/sha" },
    "generatedAt": { "$ref": "#/$defs/time" },
    "command": { "$ref": "#/$defs/text" },
    "environment": { "type": "object", "additionalProperties": { "type": "string" } },
    "verifiesInvariantIds": { "$ref": "#/$defs/ids" },
    "nodeProofReceiptId": { "$ref": "#/$defs/text" },
    "result": { "enum": ["pass", "fail", "partial", "informational"] }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._:-]+$" },
    "text": { "type": "string", "minLength": 1 },
    "ids": { "type": "array", "items": { "$ref": "#/$defs/id" }, "uniqueItems": true },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "time": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }
  },
  "additionalProperties": false
}
