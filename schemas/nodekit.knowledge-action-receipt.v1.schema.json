{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.knowledge-action-receipt.v1.schema.json",
  "title": "NodeKit knowledge action receipt",
  "type": "object",
  "required": ["schemaVersion", "receiptId", "graphId", "graphVersion", "runId", "caseId", "actorId", "type", "input", "outputRefs", "evidenceRefs", "budget", "status", "occurredAt"],
  "properties": {
    "schemaVersion": { "const": "nodekit.knowledge-action-receipt/v1" },
    "receiptId": { "$ref": "#/$defs/nonEmpty" },
    "graphId": { "$ref": "#/$defs/nonEmpty" },
    "graphVersion": { "type": "integer", "minimum": 0 },
    "runId": { "type": "string" },
    "caseId": { "type": "string" },
    "actorId": { "type": "string" },
    "type": { "enum": ["GRAPH_RETRIEVE", "EXTERNAL_RESEARCH", "PROPOSE_GRAPH_PATCH", "INSPECT_ARTIFACT", "EXECUTE_TOOL", "REQUEST_APPROVAL", "COMPLETE", "ABSTAIN"] },
    "input": { "type": "object" },
    "outputRefs": { "$ref": "#/$defs/stringList" },
    "evidenceRefs": { "$ref": "#/$defs/stringList" },
    "budget": { "type": "object" },
    "status": { "enum": ["planned", "completed", "failed", "abstained", "awaiting_approval"] },
    "occurredAt": { "$ref": "#/$defs/dateTime" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$" },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  },
  "additionalProperties": false
}
