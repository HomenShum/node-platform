{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.skill-promotion-approval.v1.schema.json",
  "title": "NodeKit purpose-scoped detached skill promotion approval",
  "type": "object",
  "required": ["schemaVersion", "purpose", "approvalId", "approvalHash", "candidateId", "candidateSkillHash", "benchmarkVerdictHash", "canaryReceiptHash", "integrityReceiptHash", "currentHarnessVersion", "currentHarnessManifestHash", "approvedBy", "nonce", "issuedAt", "expiresAt", "attestation"],
  "properties": {
    "schemaVersion": { "const": "nodekit.skill-promotion-approval/v1" },
    "purpose": { "const": "skill-promotion-approval" },
    "approvalId": { "type": "string", "pattern": "^skill-promotion-approval:sha256:[a-f0-9]{64}$" },
    "approvalHash": { "$ref": "#/$defs/hash" },
    "candidateId": { "$ref": "#/$defs/nonEmpty" },
    "candidateSkillHash": { "$ref": "#/$defs/hash" },
    "benchmarkVerdictHash": { "$ref": "#/$defs/hash" },
    "canaryReceiptHash": { "$ref": "#/$defs/hash" },
    "integrityReceiptHash": { "$ref": "#/$defs/hash" },
    "currentHarnessVersion": { "$ref": "#/$defs/nonEmpty" },
    "currentHarnessManifestHash": { "$ref": "#/$defs/hash" },
    "approvedBy": { "$ref": "#/$defs/nonEmpty" },
    "nonce": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{15,127}$" },
    "issuedAt": { "$ref": "#/$defs/dateTime" },
    "expiresAt": { "$ref": "#/$defs/dateTime" },
    "attestation": { "$ref": "#/$defs/attestation" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$" },
    "attestation": {
      "type": "object",
      "required": ["schemaVersion", "algorithm", "signatureEncoding", "keyId", "purpose", "payloadSha256", "signedAt", "signature"],
      "properties": {
        "schemaVersion": { "const": "nodekit.skill-detached-attestation/v1" },
        "algorithm": { "const": "Ed25519" },
        "signatureEncoding": { "const": "base64url" },
        "keyId": { "$ref": "#/$defs/nonEmpty" },
        "purpose": { "const": "skill-promotion-approval" },
        "payloadSha256": { "$ref": "#/$defs/hash" },
        "signedAt": { "$ref": "#/$defs/dateTime" },
        "signature": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
