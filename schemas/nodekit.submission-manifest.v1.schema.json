{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodekit.dev/schemas/nodekit.submission-manifest.v1.schema.json",
  "title": "NodeKit submission manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "candidateCommit", "gates"],
  "properties": {
    "schemaVersion": { "const": "nodekit.submission-manifest/v1" },
    "candidateCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "gates": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "passed", "evidence"],
        "properties": {
          "id": { "enum": ["developerTimingMatrix", "freshAgentHeldout", "freshHumanUsability", "threeConvexConsumers", "previewDeployment", "proofloopEaseVerification", "packageInstallProof", "publicationApproval"] },
          "passed": { "type": "boolean" },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "sha256"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          }
        }
      }
    }
  }
}
