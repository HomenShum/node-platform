{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodekit.dev/schemas/nodekit.submission-candidate.v1.schema.json",
  "title": "NodeKit externally approvable submission candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "candidateCommit", "candidateSourceHash", "releaseCandidate", "evidenceRootSha256", "gates"],
  "properties": {
    "schemaVersion": { "const": "nodekit.submission-candidate/v1" },
    "candidateCommit": { "$ref": "#/$defs/commit" },
    "candidateSourceHash": { "$ref": "#/$defs/sha256" },
    "releaseCandidate": { "$ref": "#/$defs/releaseCandidate" },
    "evidenceRootSha256": { "$ref": "#/$defs/sha256" },
    "gates": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "prefixItems": [
        { "$ref": "#/$defs/developerTimingMatrix" },
        { "$ref": "#/$defs/freshAgentHeldout" },
        { "$ref": "#/$defs/freshHumanUsability" },
        { "$ref": "#/$defs/threeConvexConsumers" },
        { "$ref": "#/$defs/previewDeployment" },
        { "$ref": "#/$defs/managedSupabasePortability" },
        { "$ref": "#/$defs/knowledgeEvolutionAdoption" },
        { "$ref": "#/$defs/modelIntelligenceHarness" },
        { "$ref": "#/$defs/engineeringHealth" },
        { "$ref": "#/$defs/proofloopEaseVerification" },
        { "$ref": "#/$defs/packageInstallProof" }
      ],
      "items": false
    }
  },
  "$defs": {
    "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!\\./)(?!.*//)(?!.*\\/$)(?!.*(?:^|/)\\.\\.?(?:/|$))(?![A-Za-z]:)[^\\\\]+$" },
    "releaseCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodekitCommit", "nodekitSourceHash", "nodekitTarballSha256", "packageName", "packageVersion"],
      "properties": {
        "nodekitCommit": { "$ref": "#/$defs/commit" },
        "nodekitSourceHash": { "$ref": "#/$defs/sha256" },
        "nodekitTarballSha256": { "$ref": "#/$defs/sha256" },
        "packageName": { "const": "@homenshum/nodekit" },
        "packageVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "passed", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "passed": { "const": true },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evidence" }
        }
      }
    },
    "developerTimingMatrix": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "developerTimingMatrix" } } },
    "freshAgentHeldout": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "freshAgentHeldout" } } },
    "freshHumanUsability": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "freshHumanUsability" } } },
    "threeConvexConsumers": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "threeConvexConsumers" } } },
    "previewDeployment": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "previewDeployment" } } },
    "managedSupabasePortability": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "managedSupabasePortability" } } },
    "knowledgeEvolutionAdoption": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "knowledgeEvolutionAdoption" } } },
    "modelIntelligenceHarness": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "modelIntelligenceHarness" } } },
    "engineeringHealth": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "engineeringHealth" } } },
    "proofloopEaseVerification": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "proofloopEaseVerification" } } },
    "packageInstallProof": { "$ref": "#/$defs/gate", "properties": { "id": { "const": "packageInstallProof" } } }
  }
}
