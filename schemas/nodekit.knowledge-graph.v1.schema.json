{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.knowledge-graph.v1.schema.json",
  "title": "NodeKit governed multimodal knowledge hypergraph",
  "type": "object",
  "required": ["schemaVersion", "graphId", "version", "authority", "layers", "nodes", "hyperedges", "proposals", "actionReceipts", "evolutionReceipts", "genesis", "createdAt", "updatedAt", "contentHash"],
  "properties": {
    "schemaVersion": { "const": "nodekit.knowledge-graph/v1" },
    "graphId": { "$ref": "#/$defs/nonEmpty" },
    "version": { "type": "integer", "minimum": 0 },
    "authority": {
      "type": "object",
      "required": ["canonicalMutation", "destructiveDelete", "oneAuthoritativeGraph"],
      "properties": {
        "canonicalMutation": { "const": "accepted-patch-only" },
        "destructiveDelete": { "const": false },
        "oneAuthoritativeGraph": { "const": true }
      },
      "additionalProperties": false
    },
    "layers": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["id", "writableThrough"],
        "properties": {
          "id": { "enum": ["source", "derived", "working", "proposal", "canonical", "hypothesis"] },
          "writableThrough": { "enum": ["ingest-proposal", "graph-patch"] }
        },
        "additionalProperties": false
      }
    },
    "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
    "hyperedges": { "type": "array", "items": { "$ref": "#/$defs/hyperedge" } },
    "proposals": { "type": "array", "items": { "type": "object" } },
    "actionReceipts": { "type": "array", "items": { "type": "object" } },
    "evolutionReceipts": { "type": "array", "items": { "type": "object" } },
    "genesis": { "type": "object", "required": ["createdAt", "graphId"] },
    "createdAt": { "$ref": "#/$defs/dateTime" },
    "updatedAt": { "$ref": "#/$defs/dateTime" },
    "contentHash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*Z$" },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "layer": { "enum": ["source", "derived", "working", "proposal", "canonical", "hypothesis"] },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "node": {
      "type": "object",
      "required": ["id", "kind", "label", "layer", "confidence", "evidenceRefs"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmpty" },
        "kind": { "$ref": "#/$defs/nonEmpty" },
        "label": { "$ref": "#/$defs/nonEmpty" },
        "layer": { "$ref": "#/$defs/layer" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceRefs": { "$ref": "#/$defs/stringList" },
        "properties": { "type": "object" },
        "contentHash": { "$ref": "#/$defs/hash" },
        "sourceUri": { "type": "string", "minLength": 1 },
        "capturedAt": { "$ref": "#/$defs/dateTime" },
        "region": { "type": "object" },
        "timeRange": { "type": "object" },
        "freshness": { "type": "object" },
        "createdAt": { "$ref": "#/$defs/dateTime" },
        "updatedAt": { "$ref": "#/$defs/dateTime" },
        "deprecatedAt": { "$ref": "#/$defs/dateTime" },
        "deprecationReason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "hyperedge": {
      "type": "object",
      "required": ["id", "predicate", "layer", "participants", "confidence", "evidenceRefs"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmpty" },
        "predicate": { "$ref": "#/$defs/nonEmpty" },
        "layer": { "$ref": "#/$defs/layer" },
        "participants": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["nodeId", "role"],
            "properties": { "nodeId": { "$ref": "#/$defs/nonEmpty" }, "role": { "$ref": "#/$defs/nonEmpty" } },
            "additionalProperties": false
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidenceRefs": { "$ref": "#/$defs/stringList" },
        "properties": { "type": "object" },
        "createdAt": { "$ref": "#/$defs/dateTime" },
        "updatedAt": { "$ref": "#/$defs/dateTime" },
        "deprecatedAt": { "$ref": "#/$defs/dateTime" },
        "deprecationReason": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
