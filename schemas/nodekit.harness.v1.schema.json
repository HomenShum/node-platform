{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.harness.v1.schema.json",
  "title": "NodeKit Harness Gym configuration",
  "type": "object",
  "required": ["schemaVersion", "applicationId", "version", "evaluation", "modelIntelligence", "promotion"],
  "properties": {
    "schemaVersion": { "const": "nodekit.harness/v1" },
    "applicationId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^h[0-9]+$" },
    "evaluation": {
      "type": "object",
      "required": ["protectedTaskRoots", "candidateMayModify"],
      "properties": {
        "protectedTaskRoots": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "candidateMayModify": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "modelIntelligence": {
      "type": "object",
      "required": ["observationRoot", "cardRoot", "findingsLedger"],
      "properties": {
        "observationRoot": { "type": "string", "minLength": 1 },
        "cardRoot": { "type": "string", "minLength": 1 },
        "findingsLedger": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "gyms": {
      "type": "object",
      "properties": {
        "builder": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "promotion": {
      "type": "object",
      "required": ["automatic", "freshAgentCanary", "proofReceipt"],
      "properties": {
        "automatic": { "const": false },
        "freshAgentCanary": { "const": true },
        "proofReceipt": { "const": true }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
