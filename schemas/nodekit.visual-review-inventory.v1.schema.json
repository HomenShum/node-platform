{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodekit.dev/schemas/nodekit.visual-review-inventory.v1.schema.json",
  "title": "NodeKit automated visual review issue inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "runId", "taskId", "nodekitCommit", "nodekitSourceHash", "nodekitTarballSha256",
    "postAgentTreeHash", "candidateArchiveSha256", "applicationHash", "configHash", "browserManifestSha256",
    "screenshotEvidenceRootSha256", "evaluatorScreenshotSha256", "isolation", "isolationSha256", "screenshotCount", "issues", "openIssueCounts",
    "automatedReview", "separateFromHumanUsability", "humanUsabilityGateSatisfied", "producer", "generatedAt", "passed", "inventorySha256"
  ],
  "properties": {
    "schemaVersion": { "const": "nodekit.visual-review-inventory/v1" }, "runId": { "type": "string", "minLength": 1 },
    "taskId": { "enum": ["research-map", "volunteer-onboarding", "launch-presentation"] },
    "nodekitCommit": { "$ref": "#/$defs/commit" }, "nodekitSourceHash": { "$ref": "#/$defs/sha256" },
    "nodekitTarballSha256": { "$ref": "#/$defs/sha256" }, "postAgentTreeHash": { "$ref": "#/$defs/commit" },
    "candidateArchiveSha256": { "$ref": "#/$defs/sha256" }, "applicationHash": { "$ref": "#/$defs/sha256" },
    "configHash": { "$ref": "#/$defs/sha256" }, "browserManifestSha256": { "$ref": "#/$defs/sha256" },
    "screenshotEvidenceRootSha256": { "$ref": "#/$defs/sha256" }, "evaluatorScreenshotSha256": { "$ref": "#/$defs/sha256" },
    "isolation": { "$ref": "#/$defs/isolation" }, "isolationSha256": { "$ref": "#/$defs/sha256" },
    "screenshotCount": { "const": 180 },
    "issues": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
    "openIssueCounts": { "type": "object", "additionalProperties": false, "required": ["p0", "p1", "p2", "p3"],
      "properties": { "p0": { "const": 0 }, "p1": { "const": 0 }, "p2": { "type": "integer", "minimum": 0 }, "p3": { "type": "integer", "minimum": 0 } } },
    "automatedReview": { "const": true }, "separateFromHumanUsability": { "const": true },
    "humanUsabilityGateSatisfied": { "const": false }, "producer": { "$ref": "#/$defs/producer" },
    "generatedAt": { "type": "string", "format": "date-time" }, "passed": { "const": true }, "inventorySha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "producer": { "type": "object", "additionalProperties": false,
      "required": ["authority", "candidateEvidenceAccess", "candidateHostAccess", "candidateWriteAccess", "executedAfterCandidateArchive", "externalNetworkEgress", "isolationMode"],
      "properties": { "authority": { "const": "campaign-protected-evaluator" }, "candidateEvidenceAccess": { "const": false },
        "candidateHostAccess": { "const": false }, "candidateWriteAccess": { "const": false }, "executedAfterCandidateArchive": { "const": true },
        "externalNetworkEgress": { "const": false }, "isolationMode": { "const": "docker-internal-two-container" } } },
    "mount": { "type": "object", "additionalProperties": false, "required": ["destination", "readOnly", "type"],
      "properties": { "destination": { "type": "string", "pattern": "^/" }, "readOnly": { "type": "boolean" }, "type": { "const": "bind" } } },
    "candidateContainer": { "type": "object", "additionalProperties": false, "required": ["containerId", "mounts", "readOnlyRootFilesystem"],
      "properties": { "containerId": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "mounts": { "type": "array", "minItems": 1, "maxItems": 1, "items": { "$ref": "#/$defs/mount" } }, "readOnlyRootFilesystem": { "const": true } } },
    "browserContainer": { "type": "object", "additionalProperties": false, "required": ["containerId", "mounts", "readOnlyRootFilesystem"],
      "properties": { "containerId": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "mounts": { "type": "array", "minItems": 6, "maxItems": 6, "items": { "$ref": "#/$defs/mount" } }, "readOnlyRootFilesystem": { "const": true } } },
    "browserDependency": { "type": "object", "additionalProperties": false, "required": ["destination", "fileCount", "name", "treeSha256", "version"],
      "properties": { "destination": { "enum": ["/runner/node_modules/playwright", "/runner/node_modules/playwright-core", "/runner/node_modules/@axe-core/playwright", "/runner/node_modules/axe-core"] }, "fileCount": { "type": "integer", "minimum": 1 },
        "name": { "enum": ["playwright", "playwright-core", "@axe-core/playwright", "axe-core"] }, "treeSha256": { "$ref": "#/$defs/sha256" }, "version": { "enum": ["1.61.1", "4.12.1"] } } },
    "isolation": { "type": "object", "additionalProperties": false,
      "required": ["schemaVersion", "mode", "browserLaneSha256", "browserDependencies", "docker", "image", "network", "candidateContainer", "browserContainer", "checks", "isolationSha256"],
      "properties": {
        "schemaVersion": { "const": "nodekit.protected-evaluator-isolation/v1" }, "mode": { "const": "docker-internal-two-container" },
        "browserLaneSha256": { "$ref": "#/$defs/sha256" }, "isolationSha256": { "$ref": "#/$defs/sha256" },
        "docker": { "type": "object", "additionalProperties": false, "required": ["apiVersion", "architecture", "operatingSystem", "serverVersion"],
          "properties": { "apiVersion": { "type": "string", "minLength": 1 }, "architecture": { "type": "string", "minLength": 1 }, "operatingSystem": { "type": "string", "minLength": 1 }, "serverVersion": { "type": "string", "minLength": 1 } } },
        "image": { "type": "object", "additionalProperties": false, "required": ["architecture", "id", "operatingSystem", "reference", "repoDigests"],
          "properties": { "architecture": { "type": "string", "minLength": 1 }, "id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }, "operatingSystem": { "type": "string", "minLength": 1 }, "reference": { "type": "string", "minLength": 1 }, "repoDigests": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } } } },
        "network": { "type": "object", "additionalProperties": false, "required": ["driver", "internal", "networkId"],
          "properties": { "driver": { "const": "bridge" }, "internal": { "const": true }, "networkId": { "type": "string", "pattern": "^[a-f0-9]{64}$" } } },
        "browserDependencies": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/browserDependency" } },
        "candidateContainer": { "$ref": "#/$defs/candidateContainer" }, "browserContainer": { "$ref": "#/$defs/browserContainer" },
        "checks": { "type": "object", "additionalProperties": false,
          "required": ["browserCannotReadCandidate", "browserEgressBlocked", "browserReadOnlyRootFilesystem", "candidateCertificationOracleAbsent", "candidateEgressBlocked", "candidateHasNoEvidenceMount", "candidateReadOnlyRootFilesystem", "candidateSourceReadOnly", "exactImageBound", "hostNamespacesNotShared", "internalNetworkOnly", "noPublishedPorts", "separateEvaluatorContainer"],
          "properties": { "browserCannotReadCandidate": { "const": true }, "browserEgressBlocked": { "const": true }, "browserReadOnlyRootFilesystem": { "const": true }, "candidateCertificationOracleAbsent": { "const": true }, "candidateEgressBlocked": { "const": true }, "candidateHasNoEvidenceMount": { "const": true }, "candidateReadOnlyRootFilesystem": { "const": true }, "candidateSourceReadOnly": { "const": true }, "exactImageBound": { "const": true }, "hostNamespacesNotShared": { "const": true }, "internalNetworkOnly": { "const": true }, "noPublishedPorts": { "const": true }, "separateEvaluatorContainer": { "const": true } } }
      } },
    "issue": { "type": "object", "additionalProperties": false, "required": ["code", "message", "severity"],
      "properties": { "code": { "type": "string", "minLength": 1 }, "message": { "type": "string", "minLength": 1 }, "severity": { "enum": ["p0", "p1", "p2", "p3"] } } }
  }
}
