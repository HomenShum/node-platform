{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.routing-policy.v1.schema.json",
  "title": "NodeKit capability-driven routing policy",
  "type": "object",
  "required": ["schemaVersion", "applicationId", "status", "evidencePrecedence", "routes", "automaticPromotion"],
  "properties": {
    "schemaVersion": { "const": "nodekit.routing-policy/v1" },
    "applicationId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["provisional", "canary-passed", "promoted", "expired"] },
    "evidencePrecedence": { "const": ["project", "domain", "ecosystem", "unprofiled-fallback"] },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["taskFamily", "requiredCapabilities", "candidates", "fallback", "completion"],
        "properties": {
          "taskFamily": { "type": "string", "minLength": 1 },
          "requiredCapabilities": { "$ref": "#/$defs/stringList" },
          "candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["requestedRoute", "resolvedProvider", "resolvedModel", "scope", "confidence", "priority", "roleSkills", "domainSkills", "modelAdapters", "guardrails", "evidenceRefs"],
              "properties": {
                "requestedRoute": { "type": "string", "minLength": 1 },
                "resolvedProvider": { "type": "string", "minLength": 1 },
                "resolvedModel": { "type": "string", "minLength": 1 },
                "scope": { "enum": ["project", "domain", "ecosystem"] },
                "confidence": { "enum": ["low", "medium", "high"] },
                "priority": { "type": "integer", "minimum": 1 },
                "roleSkills": { "$ref": "#/$defs/stringList" },
                "domainSkills": { "$ref": "#/$defs/stringList" },
                "modelAdapters": { "$ref": "#/$defs/stringList" },
                "guardrails": { "$ref": "#/$defs/stringList" },
                "evidenceRefs": { "$ref": "#/$defs/nonEmptyStringList" }
              },
              "additionalProperties": false
            }
          },
          "fallback": {
            "type": "object",
            "required": ["type", "skill"],
            "properties": {
              "type": { "const": "deterministic" },
              "skill": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          },
          "completion": {
            "type": "object",
            "required": ["requireProposal", "requireArtifactInspection", "directMutation"],
            "properties": {
              "requireProposal": { "const": true },
              "requireArtifactInspection": { "const": true },
              "directMutation": { "const": false }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "automaticPromotion": { "const": false },
    "compiledFrom": {
      "type": "object",
      "required": ["harnessHash", "benchmarkHash", "cardHashes"],
      "properties": {
        "harnessHash": { "$ref": "#/$defs/hash" },
        "benchmarkHash": { "$ref": "#/$defs/hash" },
        "cardHashes": { "type": "array", "items": { "$ref": "#/$defs/hash" }, "uniqueItems": true }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "stringList": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "nonEmptyStringList": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
  },
  "additionalProperties": false
}
