{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.product-design-contract.v1.schema.json",
  "title": "NodeKit protected product design contract",
  "type": "object",
  "required": ["schemaVersion", "contractId", "product", "journey", "designIntent", "interfaceHypothesis", "requiredDesktopSurfaces", "requiredMobileSurfaces", "avoid", "requiredStates", "protectedDecisions"],
  "properties": {
    "schemaVersion": { "const": "nodekit.product-design-contract/v1" },
    "contractId": { "$ref": "#/$defs/nonEmpty" },
    "product": {
      "type": "object",
      "required": ["targetUser", "primaryJob", "primaryArtifact"],
      "properties": {
        "targetUser": { "$ref": "#/$defs/nonEmpty" },
        "primaryJob": { "$ref": "#/$defs/nonEmpty" },
        "primaryArtifact": { "$ref": "#/$defs/nonEmpty" }
      },
      "additionalProperties": false
    },
    "journey": { "$ref": "#/$defs/nonEmptyStrings" },
    "designIntent": {
      "type": "object",
      "required": ["emotionalTarget", "dominantSurface", "dominantAction", "density"],
      "properties": {
        "emotionalTarget": { "$ref": "#/$defs/nonEmptyStrings" },
        "dominantSurface": { "$ref": "#/$defs/nonEmpty" },
        "dominantAction": { "$ref": "#/$defs/nonEmpty" },
        "density": { "enum": ["low", "medium", "high"] }
      },
      "additionalProperties": false
    },
    "interfaceHypothesis": {
      "type": "object",
      "required": ["artifactDominance", "agentPlacement", "reviewBoundary", "mobileTopology"],
      "properties": {
        "artifactDominance": { "$ref": "#/$defs/nonEmpty" },
        "agentPlacement": { "$ref": "#/$defs/nonEmpty" },
        "reviewBoundary": { "$ref": "#/$defs/nonEmpty" },
        "mobileTopology": { "$ref": "#/$defs/nonEmpty" }
      },
      "additionalProperties": false
    },
    "requiredDesktopSurfaces": { "$ref": "#/$defs/nonEmptyStrings" },
    "requiredMobileSurfaces": { "$ref": "#/$defs/nonEmptyStrings" },
    "avoid": { "$ref": "#/$defs/nonEmptyStrings" },
    "requiredStates": { "$ref": "#/$defs/nonEmptyStrings" },
    "protectedDecisions": {
      "type": "object",
      "required": ["primaryUser", "primaryJob", "canonicalWorkflow", "dataAuthority", "permissionBoundaries", "completionCriteria", "finalVerdict"],
      "properties": {
        "primaryUser": { "const": "nodekit" },
        "primaryJob": { "const": "nodekit" },
        "canonicalWorkflow": { "const": "nodekit" },
        "dataAuthority": { "const": "nodekit" },
        "permissionBoundaries": { "const": "nodekit" },
        "completionCriteria": { "const": "nodeproof" },
        "finalVerdict": { "const": "nodeproof" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "nonEmptyStrings": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmpty" }, "uniqueItems": true }
  },
  "additionalProperties": false
}
