{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.design-decision.v1.schema.json",
  "title": "NodeKit independent frontend direction decision",
  "type": "object",
  "required": ["schemaVersion", "decisionId", "directionSetId", "candidateIds", "selectedCandidateId", "selectionReasons", "criticReceiptIds", "humanDecision", "independentSelector", "protectedEvaluatorUnchanged", "decidedAt"],
  "properties": {
    "schemaVersion": { "const": "nodekit.design-decision/v1" },
    "decisionId": { "type": "string", "minLength": 1 },
    "directionSetId": { "type": "string", "minLength": 1 },
    "candidateIds": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "selectedCandidateId": { "type": "string", "minLength": 1 },
    "selectionReasons": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "criticReceiptIds": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "humanDecision": { "type": "boolean" },
    "independentSelector": { "const": true },
    "protectedEvaluatorUnchanged": { "const": true },
    "decidedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T" }
  },
  "additionalProperties": false
}
