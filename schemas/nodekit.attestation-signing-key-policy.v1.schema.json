{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodekit.dev/schemas/nodekit.attestation-signing-key-policy.v1.schema.json",
  "title": "NodeKit one-purpose evidence-finalization signing policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "keyId", "publicKey", "purposes"],
  "properties": {
    "schemaVersion": { "const": "nodekit.attestation-signing-key-policy/v1" },
    "keyId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{0,127}$" },
    "publicKey": { "type": "string", "minLength": 1 },
    "purposes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "developerTimingMatrix",
          "freshAgentHeldout",
          "freshHumanUsability",
          "threeConvexConsumers",
          "previewDeployment",
          "managedSupabasePortability",
          "knowledgeEvolutionAdoption",
          "modelIntelligenceHarness",
          "proofloopEaseVerification",
          "publicationApproval"
        ]
      }
    }
  }
}
