{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.skill-promotion-approval-consumption.v1.schema.json",
  "title": "NodeKit one-time skill promotion approval consumption",
  "type": "object",
  "required": [
    "schemaVersion",
    "approvalId",
    "approvalHash",
    "approvalNonce",
    "candidateId",
    "promotionId",
    "targetHarnessVersion",
    "consumedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "nodekit.skill-promotion-approval-consumption/v1" },
    "approvalId": { "type": "string", "pattern": "^skill-promotion-approval:sha256:[a-f0-9]{64}$" },
    "approvalHash": { "$ref": "#/$defs/hash" },
    "approvalNonce": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]{15,127}$" },
    "candidateId": { "$ref": "#/$defs/nonEmpty" },
    "promotionId": { "$ref": "#/$defs/nonEmpty" },
    "targetHarnessVersion": { "type": "string", "pattern": "^h[0-9]+$" },
    "consumedAt": { "$ref": "#/$defs/dateTime" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "dateTime": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$" }
  },
  "additionalProperties": false
}
