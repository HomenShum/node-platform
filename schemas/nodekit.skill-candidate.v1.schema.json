{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HomenShum/node-platform/blob/main/schemas/nodekit.skill-candidate.v1.schema.json",
  "title": "NodeKit proposal-only skill candidate",
  "type": "object",
  "required": ["schemaVersion", "candidateId", "status", "hypothesis", "expectedImpact", "risks", "sourceCluster", "skillFile", "protectedBenchmarkHash", "createdFromEvidence"],
  "properties": {
    "schemaVersion": { "const": "nodekit.skill-candidate/v1" },
    "candidateId": { "type": "string", "pattern": "^skill-candidate-[a-z0-9-]+$" },
    "status": { "enum": ["proposed", "benchmark-passed", "benchmark-failed", "canary-passed", "promoted", "rejected"] },
    "hypothesis": { "type": "string", "minLength": 1 },
    "expectedImpact": { "type": "string", "minLength": 1 },
    "risks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "sourceCluster": {
      "type": "object",
      "required": ["failureClass", "probableCause", "model", "count", "taskIds", "taskFamilies", "evidenceRefs"],
      "properties": {
        "failureClass": { "type": "string", "minLength": 1 },
        "probableCause": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 3 },
        "taskIds": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "taskFamilies": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "evidenceRefs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      },
      "additionalProperties": false
    },
    "skillFile": { "type": "string", "minLength": 1 },
    "protectedBenchmarkHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "createdFromEvidence": { "const": true }
  },
  "additionalProperties": false
}
