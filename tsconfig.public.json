{
  "compilerOptions": {
    "allowJs": false,
    "exactOptionalPropertyTypes": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": false,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "src/**/*.d.ts",
    "src/**/*.d.mts",
    "test/types/**/*.ts"
  ]
}
