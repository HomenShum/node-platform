{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nodekit.smb-lending-receipt/v1",
  "type": "object",
  "required": ["schemaVersion", "sessionId", "caseId", "applicationHash", "candidate", "configHash", "documents", "events", "graph", "proposals", "readiness", "replay", "safety", "sourcePackets", "sessionDigest", "sessionSnapshot", "receiptDigest"],
  "properties": {
    "schemaVersion": { "const": "nodekit.smb-lending-receipt/v1" },
    "sessionId": { "type": "string" },
    "configHash": { "type": "string" },
    "documents": { "type": "array" },
    "proposals": { "type": "array" },
    "sourcePackets": { "type": "array", "minItems": 1 },
    "sessionDigest": { "type": "string", "minLength": 64 },
    "receiptDigest": { "type": "string", "minLength": 64 }
  }
}
